{
  "$schema": "https://static.modelcontextprotocol.io/schemas/v1/server.schema.json",
  "name": "example-org/with-package",
  "version": "0.4.2",
  "description": "Server document with a locally-runnable npm package.",
  "repository": {
    "url": "https://github.com/example-org/with-package",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@example-org/with-package",
      "version": "0.4.2",
      "runtimeHint": "npx",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "EXAMPLE_API_KEY",
          "description": "Example API key.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
